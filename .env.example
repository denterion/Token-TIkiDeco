SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_WITH_TEST_ETH_ONLY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Canonical Sepolia V1 scripts only.
OWNER_ADDRESS=0xYOUR_OWNER_WALLET_ADDRESS
TREASURY_ADDRESS=0xYOUR_TREASURY_OR_MULTISIG_ADDRESS

# Non-canonical V2 candidate deployment scripts.
# Public-network V2 deployment fails closed unless every role address is explicit.
CONFIRM_NON_CANONICAL_V2_DEPLOY=false
V2_DEFAULT_ADMIN_ADDRESS=0xYOUR_SAFE_OR_ADMIN_ADDRESS
V2_PAUSER_ADDRESS=0xYOUR_PAUSER_ADDRESS
V2_REPORTER_ADDRESS=0xYOUR_REPORTER_ADDRESS
V2_VESTING_ADMIN_ADDRESS=0xYOUR_VESTING_ADMIN_ADDRESS
V2_TREASURY_ADDRESS=0xYOUR_TREASURY_ADDRESS
V2_DEFAULT_ADMIN_DELAY_SECONDS=86400
PROJECT_NAME=TikiDeco Sepolia prototype
BUSINESS_ENTITY=TikiDeco project company / SPV to be formed
PROJECT_JURISDICTION=Florida, USA
PROJECT_URI=https://tikideco.xyz/project

# Optional vesting beneficiaries for planning scripts.
TEAM_BENEFICIARY=0xTEAM_OR_MULTISIG_ADDRESS
PARTNERS_BENEFICIARY=0xPARTNERS_OR_MULTISIG_ADDRESS
COMMUNITY_BENEFICIARY=0xCOMMUNITY_REWARDS_ADDRESS
HOTEL_PERKS_BENEFICIARY=0xHOTEL_PERKS_ADDRESS
