{
  "name": "tikideco-token",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source Ethereum Sepolia prototype for transparent hospitality-linked token infrastructure.",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "tokenomics": "hardhat run scripts/print-tokenomics.cjs",
    "report:hash": "hardhat run scripts/hash-report.cjs",
    "report:publish:direct-owner:sepolia": "hardhat run scripts/publish-report.cjs --network sepolia",
    "report:safe:sepolia": "hardhat run scripts/prepare-safe-report-publication.cjs --network sepolia",
    "vesting:plan": "hardhat run scripts/plan-vesting.cjs",
    "owner:check:sepolia": "hardhat run scripts/check-owner-state.cjs --network sepolia",
    "safe:handover:sepolia": "hardhat run scripts/prepare-safe-ownership-handover.cjs --network sepolia",
    "ownership:propose:sepolia": "hardhat run scripts/propose-ownership-transfer.cjs --network sepolia",
    "ownership:accept:sepolia": "hardhat run scripts/accept-ownership-transfer.cjs --network sepolia",
    "sepolia:check": "hardhat run scripts/check-sepolia-readiness.cjs",
    "sepolia:state": "hardhat run scripts/check-deployment-state.cjs --network sepolia",
    "wallet:check": "hardhat run scripts/check-wallet-config.cjs",
    "deploy:localhost": "hardhat run scripts/deploy.cjs --network localhost",
    "deploy:v2:localhost": "hardhat run scripts/deploy-v2.cjs --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.cjs --network sepolia",
    "deploy:v2:sepolia": "hardhat run scripts/deploy-v2.cjs --network sepolia",
    "verify:sepolia": "node scripts/verify-sepolia.cjs",
    "coverage": "hardhat test --coverage",
    "audit:deps": "npm audit --audit-level=moderate",
    "audit": "npm run audit:deps && npm run audit:package",
    "lint": "npm run compile && node scripts/check-deployment-manifest.cjs && node scripts/check-bytecode-size.cjs",
    "site:dev": "vite --config site-v2/vite.config.ts --host 127.0.0.1",
    "site:build": "node scripts/build-site-manifest.cjs && node scripts/clean-site-v2-assets.cjs && vite build --config site-v2/vite.config.ts && node scripts/build-site-pages.cjs",
    "site:preview": "vite preview --config site-v2/vite.config.ts --host 127.0.0.1",
    "eligibility:test": "node scripts/test-eligibility-engine.cjs",
    "eligibility": "npm run eligibility:test",
    "allocation:prepare": "node scripts/prepare-testnet-allocation.cjs",
    "allocation:check": "node scripts/check-allocation-report.cjs",
    "allocation": "npm run allocation:check",
    "pilot:report:check": "node scripts/check-pilot-report.cjs",
    "pilot:report": "npm run pilot:report:check",
    "pilot:campaign:check": "node scripts/check-pilot-campaign.cjs",
    "pilot:campaign": "npm run pilot:campaign:check",
    "pilot:live:check": "node scripts/check-pilot-live-readiness.cjs",
    "pilot:live:blocked": "node scripts/check-pilot-live-readiness.cjs --expect-blocked",
    "pilot:check": "npm run eligibility && npm run allocation && node scripts/check-pilot-campaign.cjs && npm run claims",
    "pilot": "npm run pilot:check",
    "site:check": "npm run eligibility:test && npm run site:build && node scripts/check-site-content.cjs && node scripts/check-site-v2.cjs",
    "release:check": "node scripts/check-release-draft.cjs",
    "release:package": "node scripts/generate-audit-release-package.cjs",
    "release": "npm run release:check",
    "audit:package": "node scripts/generate-v2-audit-package.cjs",
    "audit:handoff:check": "node scripts/check-audit-handoff.cjs",
    "audit:handoff": "npm run audit:handoff:check",
    "claims:check": "node scripts/check-public-claims.cjs",
    "claims": "npm run claims:check",
    "mainnet:check": "node scripts/check-mainnet-readiness.cjs",
    "mainnet": "npm run mainnet:check",
    "value:check": "node scripts/check-value-claims.cjs",
    "value": "npm run value:check",
    "v02:rc:check": "node scripts/check-v02-rc.cjs",
    "v02:rc": "npm run v02:rc:check",
    "bytecode:size": "node scripts/check-bytecode-size.cjs",
    "bytecode": "npm run bytecode:size",
    "manifest:check": "node scripts/check-deployment-manifest.cjs",
    "manifest": "npm run manifest:check",
    "manifest:source": "node scripts/check-manifest-source-config.cjs",
    "gas:snapshot": "hardhat test --gas-stats",
    "gas": "npm run gas:snapshot",
    "site": "npm run site:check",
    "foundry:test": "node scripts/run-foundry.cjs test --fuzz-seed 0x54494b494445434f5f56325f46555a5a5f534545445f3030303030303031",
    "foundry:coverage": "node scripts/run-foundry.cjs coverage --report lcov --fuzz-seed 0x54494b494445434f5f56325f46555a5a5f534545445f3030303030303031 && node scripts/check-coverage-thresholds.cjs lcov.info 75 60 35 contracts/TikiDecoTokenV2.sol contracts/TikiDecoVestingVaultV2.sol",
    "artifacts:contracts": "node scripts/export-contract-artifacts.cjs",
    "sbom:spdx": "node scripts/generate-sbom.cjs",
    "checksums": "node scripts/generate-checksums.cjs",
    "workflow:pins": "node scripts/check-workflow-action-pins.cjs",
    "slither:baseline": "node scripts/check-slither-baseline.cjs",
    "slither:raw": "slither contracts --config-file slither.config.json --solc-remaps @openzeppelin/=node_modules/@openzeppelin/",
    "slither": "node scripts/run-slither-baseline-scan.cjs"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.6.1",
    "@react-three/fiber": "8.17.10",
    "framer-motion": "11.18.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "three": "0.179.1"
  },
  "overrides": {
    "diff": "9.0.0",
    "vite": {
      "esbuild": "0.28.1"
    },
    "serialize-javascript": "7.0.5",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "4.0.13",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "3.0.10",
    "@nomicfoundation/hardhat-mocha": "3.0.21",
    "@vitejs/plugin-react": "5.1.2",
    "chai": "6.2.2",
    "dotenv": "17.4.2",
    "hardhat": "3.9.0",
    "mocha": "11.7.6",
    "typescript": "6.0.3",
    "vite": "7.3.5"
  }
}
