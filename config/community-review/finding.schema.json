{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tikideco.xyz/schemas/community-review-finding.schema.json",
  "title": "TikiDeco Community Review Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "findingId",
    "reviewer",
    "candidateCommit",
    "reference",
    "title",
    "publicSummary",
    "affectedFiles",
    "severity",
    "status",
    "description",
    "impact",
    "reproduction",
    "remediation",
    "regressionTest",
    "retestStatus",
    "retestEvidence",
    "codeChanged",
    "acceptedForDeployment",
    "disclosureStatus"
  ],
  "properties": {
    "findingId": { "type": "string", "pattern": "^CR-[0-9]{4}$" },
    "reviewer": { "type": "string", "minLength": 1, "maxLength": 120 },
    "candidateCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "type": "string", "enum": ["public-issue", "private-reference"] },
        "value": { "type": "string", "minLength": 1, "maxLength": 240 }
      }
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 160 },
    "publicSummary": { "type": "string", "minLength": 1, "maxLength": 280 },
    "affectedFiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 240 }
    },
    "severity": {
      "type": "string",
      "enum": ["Critical", "High", "Medium", "Low", "Informational", "Unassigned"]
    },
    "status": {
      "type": "string",
      "enum": ["submitted", "acknowledged", "validated", "rejected", "duplicate", "invalid", "accepted-risk", "remediation-planned", "fix-in-review", "retest", "resolved"]
    },
    "description": { "type": "string", "minLength": 1 },
    "impact": { "type": "string", "minLength": 1 },
    "reproduction": { "type": "string", "minLength": 1 },
    "remediation": { "type": "string" },
    "regressionTest": { "type": "string" },
    "retestStatus": {
      "type": "string",
      "enum": ["not-requested", "pending", "passed", "failed", "not-applicable"]
    },
    "retestEvidence": { "type": "string" },
    "codeChanged": { "type": "boolean" },
    "acceptedForDeployment": { "type": "boolean" },
    "dispositionRationale": { "type": "string" },
    "riskAcceptance": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["approver", "reviewedAt", "rationale"],
      "properties": {
        "approver": { "type": "string", "minLength": 1 },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "disclosureStatus": {
      "type": "string",
      "enum": ["private", "coordinated", "public", "not-applicable"]
    }
  }
}
